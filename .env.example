# =============================================================================
# AI Healthcare Assistant Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_NAME=AI Healthcare Assistant
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
# Set SQL_ECHO=true only when debugging SQL queries (very noisy on startup)
SQL_ECHO=false

# --- MediAI guest chat (landing page) ---
# false = fresh MediAI guest session on every page reload (default)
# true  = keep guest session across refresh (localStorage + Redis history)
GUEST_SESSION_PERSIST=false

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://healthcare:healthcare@localhost:5433/healthcare
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-64-char-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# --- LLM (Gemini primary, Groq fallback) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE_CONVERSATION=0.7
LLM_TEMPERATURE_TRIAGE=0.3

# --- Embeddings (Long-term Memory) ---
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=768

# --- AWS S3 / MinIO (Report Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=medical-reports
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email / Notifications ---
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@healthcare-assistant.local

# --- Google Calendar (stub in MVP) ---
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# --- Rate Limiting ---
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_REPORT_UPLOAD_PER_HOUR=10

# --- Security (Phase 17+) ---
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_HEADERS_ENABLED=false

# --- Observability (Phase 18) ---
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
METRICS_ENABLED=false
